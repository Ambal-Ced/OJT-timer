# Copy to `.env.local` and fill in values. `.env.local` is gitignored.

# Supabase project URL (Dashboard → Project Settings → API → Project URL)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Supabase API keys (Dashboard → Project Settings → API)
# anon = public JWT for browser (@supabase/supabase-js); service_role = server-only, never commit
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Flask app: this app uses Postgres via DATABASE_URL (not the JS client keys above).
# Dashboard → Project Settings → Database → Connection string (URI mode, pooler recommended).
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?sslmode=require

SECRET_KEY=change-me-to-a-long-random-string
OJT_ADMIN_PASSWORD=your-admin-password
